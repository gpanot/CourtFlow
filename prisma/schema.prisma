generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SkillLevel {
  beginner
  intermediate
  advanced
  pro
}

enum Gender {
  male
  female
  other
}

enum CourtStatus {
  idle
  warmup
  active
  maintenance
}

enum GameType {
  men
  women
  mixed
}

enum SessionStatus {
  open
  closed
}

enum SessionType {
  open_play
  competition
}

enum CourtBlockType {
  private_competition
  private_event
  maintenance
  open_play
  competition
}

enum QueueStatus {
  waiting
  assigned
  playing
  on_break
  left
}

enum GroupStatus {
  forming
  active
  disbanded
}

enum GamePreference {
  no_preference
  same_gender
}

enum StaffRole {
  staff
  superadmin
}

enum PlayerAppAuthMethod {
  face_pwa
  wristband
  phone_otp
}

enum PaymentStatus {
  UNPAID
  PAID
}

enum MembershipStatus {
  active
  suspended
  expired
  cancelled
}

enum MembershipPaymentStatus {
  UNPAID
  PAID
  OVERDUE
}

enum BookingStatus {
  confirmed
  cancelled
  completed
  no_show
}

enum SubscriptionStatus {
  active
  exhausted
  expired
  cancelled
}

model Venue {
  id                 String    @id @default(cuid())
  name               String
  location           String?
  settings           Json      @default("{}")
  active             Boolean   @default(true)
  expectedMaxPlayers Int?      @map("expected_max_players")
  playFrequency      String?   @map("play_frequency")
  playTypes          String[]  @default([]) @map("play_types")
  painPoints         String[]  @default([]) @map("pain_points")
  logoUrl            String?   @map("logo_url")
  tvText             String?   @map("tv_text")
  bankName           String?   @map("bank_name")
  bankAccount        String?   @map("bank_account")
  bankOwnerName      String?   @map("bank_owner_name")
  createdAt          DateTime  @default(now()) @map("created_at")

  billingStatus String @default("active") @map("billing_status")

  courts               Court[]
  sessions             Session[]
  staff                StaffMember[]
  auditLogs            AuditLog[]
  membershipTiers      MembershipTier[]
  memberships          Membership[]
  bookings             Booking[]
  courtBlocks          CourtBlock[]
  coachPackages        CoachPackage[]
  coachLessons         CoachLesson[]
  pendingPayments      PendingPayment[]
  checkInPlayers       CheckInPlayer[]
  subscriptionPackages SubscriptionPackage[]
  checkInRecords       CheckInRecord[]
  billingRate          VenueBillingRate?
  billingInvoices      BillingInvoice[]

  @@map("venues")
}

model Player {
  id                    String         @id @default(cuid())
  name                  String
  phone                 String         @unique
  avatar                String         @default("🏓")
  skillLevel            SkillLevel     @default(beginner) @map("skill_level")
  gender                Gender
  gamePreference        GamePreference @default(no_preference) @map("game_preference")
  notificationsEnabled  Boolean        @default(false) @map("notifications_enabled")
  faceSubjectId         String?        @map("face_subject_id")
  /// Public URL path served from /uploads (e.g. /uploads/players/{id}.jpg) — set on first face check-in enrollment
  facePhotoPath         String?        @map("face_photo_path")
  /// Player-uploaded avatar photo, takes priority over facePhotoPath for display
  avatarPhotoPath       String?        @map("avatar_photo_path")
  rankingScore          Int            @default(200) @map("ranking_score")
  rankingCount          Int            @default(0) @map("ranking_count")
  lastRankedAt          DateTime?      @map("last_ranked_at")
  createdAt             DateTime       @default(now()) @map("created_at")

  queueEntries      QueueEntry[]
  playerRankings    PlayerRanking[]
  pushSubscriptions PushSubscription[]
  memberships       Membership[]
  bookings          Booking[]
  coachLessons      CoachLesson[]
  faceAttempts      FaceAttempt[]
  appAuthLogs       PlayerAppAuthLog[]
  pendingPayments   PendingPayment[]

  @@map("players")
}

model PlayerAppAuthLog {
  id        String              @id @default(cuid())
  playerId  String              @map("player_id")
  method    PlayerAppAuthMethod
  sessionId String?             @map("session_id")
  createdAt DateTime            @default(now()) @map("created_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, createdAt])
  @@map("player_app_auth_logs")
}

model PushSubscription {
  id        String   @id @default(cuid())
  playerId  String   @map("player_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model StaffMember {
  id                  String    @id @default(cuid())
  name                String
  phone               String    @unique
  email               String?   @unique
  role                StaffRole @default(staff)
  passwordHash        String    @map("password_hash")
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  isCoach             Boolean   @default(false) @map("is_coach")
  coachBio            String?   @map("coach_bio")
  coachPhoto          String?   @map("coach_photo")
  createdAt           DateTime  @default(now()) @map("created_at")

  pushNotificationsEnabled Boolean @default(false) @map("push_notifications_enabled")

  venues        Venue[]
  auditLogs     AuditLog[]
  sessions      Session[]
  payments      StaffPayment[]  @relation("StaffPayments")
  paidPayments  StaffPayment[]  @relation("PaidByStaff")
  coachPackages CoachPackage[]
  coachLessons  CoachLesson[]
  playerRankings PlayerRanking[]
  pushTokens    StaffPushToken[]

  @@map("staff_members")
}

model Court {
  id              String      @id @default(cuid())
  venueId         String      @map("venue_id")
  label           String
  status          CourtStatus @default(idle)
  activeInSession Boolean     @default(false) @map("active_in_session")
  isBookable      Boolean     @default(false) @map("is_bookable")
  /** After staff restores from maintenance/stand-by, assignments skip warmup until next maintenance. */
  skipWarmupAfterMaintenance Boolean @default(false) @map("skip_warmup_after_maintenance")

  venue            Venue              @relation(fields: [venueId], references: [id])
  courtAssignments CourtAssignment[]
  bookings         Booking[]
  coachLessons     CoachLesson[]
  playerRankings   PlayerRanking[]

  @@map("courts")
}

model Session {
  id           String        @id @default(cuid())
  venueId      String        @map("venue_id")
  staffId      String?       @map("staff_id")
  date         DateTime      @default(now())
  openedAt     DateTime      @default(now()) @map("opened_at")
  closedAt     DateTime?     @map("closed_at")
  status       SessionStatus @default(open)
  type         SessionType   @default(open_play)
  title        String?
  gameTypeMix  Json?         @map("game_type_mix")
  warmupMode   String        @default("manual") @map("warmup_mode")
  /// After the first real game starts, no new warm-up courts/assignments for this session.
  introWarmupComplete Boolean @default(false) @map("intro_warmup_complete")
  maxPlayers   Int?          @map("max_players")
  sessionFee   Int           @default(0) @map("session_fee")

  venue            Venue              @relation(fields: [venueId], references: [id])
  staff            StaffMember?       @relation(fields: [staffId], references: [id])
  queueEntries     QueueEntry[]
  playerGroups     PlayerGroup[]
  courtAssignments CourtAssignment[]
  playerRankings   PlayerRanking[]
  pendingPayments  PendingPayment[]

  @@map("sessions")
}

model QueueEntry {
  id                    String         @id @default(cuid())
  sessionId             String         @map("session_id")
  playerId              String         @map("player_id")
  groupId               String?        @map("group_id")
  joinedAt              DateTime       @default(now()) @map("joined_at")
  status                QueueStatus    @default(waiting)
  breakUntil            DateTime?      @map("break_until")
  totalPlayMinutesToday Int            @default(0) @map("total_play_minutes_today")
  gamePreference        GamePreference @default(no_preference) @map("game_preference")
  queueNumber           Int?           @map("queue_number")

  session Session      @relation(fields: [sessionId], references: [id])
  player  Player       @relation(fields: [playerId], references: [id])
  group   PlayerGroup? @relation(fields: [groupId], references: [id])

  @@unique([sessionId, playerId])
  @@map("queue_entries")
}

model PlayerGroup {
  id        String      @id @default(cuid())
  sessionId String      @map("session_id")
  code      String
  status    GroupStatus  @default(forming)
  createdAt DateTime    @default(now()) @map("created_at")

  session      Session      @relation(fields: [sessionId], references: [id])
  queueEntries QueueEntry[]

  @@unique([sessionId, code])
  @@map("player_groups")
}

model CourtAssignment {
  id        String    @id @default(cuid())
  courtId   String    @map("court_id")
  sessionId String    @map("session_id")
  playerIds String[]  @map("player_ids")
  groupIds  String[]  @map("group_ids")
  gameType  GameType  @default(mixed) @map("game_type")
  isWarmup  Boolean   @default(false) @map("is_warmup")
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  endedBy   String?   @map("ended_by")

  court   Court   @relation(fields: [courtId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  @@map("court_assignments")
}

model PlayerRanking {
  id         String   @id @default(cuid())
  playerId   String   @map("player_id")
  courtId    String   @map("court_id")
  sessionId  String   @map("session_id")
  staffId    String   @map("staff_id")
  position   Int
  scoreDelta Int      @map("score_delta")
  createdAt  DateTime @default(now()) @map("created_at")

  player  Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  court   Court       @relation(fields: [courtId], references: [id], onDelete: Cascade)
  session Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  staff   StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([sessionId, courtId])
  @@index([sessionId, courtId, createdAt])
  @@map("player_rankings")
}

model AuditLog {
  id        String   @id @default(cuid())
  venueId   String   @map("venue_id")
  staffId   String?  @map("staff_id")
  action    String
  targetId  String?  @map("target_id")
  reason    String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  venue Venue        @relation(fields: [venueId], references: [id])
  staff StaffMember? @relation(fields: [staffId], references: [id])

  @@map("audit_logs")
}

model StaffPayment {
  id        String        @id @default(cuid())
  staffId   String        @map("staff_id")
  weekStart DateTime      @map("week_start")
  totalHours Decimal      @db.Decimal(6, 1) @map("total_hours")
  amount        Decimal?      @db.Decimal(10, 0)
  paymentMethod String?       @map("payment_method")
  status        PaymentStatus @default(UNPAID)
  paidAt    DateTime?     @map("paid_at")
  paidDate  DateTime?     @map("paid_date")
  paidById  String?       @map("paid_by_id")
  note      String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  staff  StaffMember  @relation("StaffPayments", fields: [staffId], references: [id])
  paidBy StaffMember? @relation("PaidByStaff", fields: [paidById], references: [id])

  @@unique([staffId, weekStart])
  @@index([weekStart])
  @@index([staffId])
  @@map("staff_payments")
}

model MembershipTier {
  id               String   @id @default(cuid())
  venueId          String   @map("venue_id")
  sortOrder        Int      @map("sort_order")
  name             String
  priceInCents     Int      @map("price_in_cents")
  sessionsIncluded Int?     @map("sessions_included")
  showBadge        Boolean  @default(false) @map("show_badge")
  perks            Json     @default("[]")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")

  venue       Venue        @relation(fields: [venueId], references: [id])
  memberships Membership[]

  @@unique([venueId, sortOrder])
  @@map("membership_tiers")
}

model Membership {
  id           String           @id @default(cuid())
  playerId     String           @map("player_id")
  venueId      String           @map("venue_id")
  tierId       String           @map("tier_id")
  status       MembershipStatus @default(active)
  activatedAt  DateTime         @default(now()) @map("activated_at")
  renewalDate  DateTime         @map("renewal_date")
  sessionsUsed Int              @default(0) @map("sessions_used")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  player   Player              @relation(fields: [playerId], references: [id])
  venue    Venue               @relation(fields: [venueId], references: [id])
  tier     MembershipTier      @relation(fields: [tierId], references: [id])
  payments MembershipPayment[]

  @@unique([playerId, venueId])
  @@index([venueId])
  @@index([tierId])
  @@map("memberships")
}

model MembershipPayment {
  id            String                  @id @default(cuid())
  membershipId  String                  @map("membership_id")
  periodStart   DateTime                @map("period_start")
  periodEnd     DateTime                @map("period_end")
  amountInCents Int                     @map("amount_in_cents")
  status        MembershipPaymentStatus @default(UNPAID)
  paidAt        DateTime?               @map("paid_at")
  paymentMethod String?                 @map("payment_method")
  proofUrl      String?                 @map("proof_url")
  note          String?
  createdAt     DateTime                @default(now()) @map("created_at")

  membership Membership @relation(fields: [membershipId], references: [id])

  @@index([membershipId])
  @@index([status])
  @@map("membership_payments")
}

model CourtBlock {
  id        String         @id @default(cuid())
  venueId   String         @map("venue_id")
  type      CourtBlockType
  title     String?
  note      String?
  courtIds  String[]       @map("court_ids")
  date      DateTime       @db.Date
  startTime DateTime       @map("start_time")
  endTime   DateTime       @map("end_time")
  createdBy String?        @map("created_by")
  createdAt DateTime       @default(now()) @map("created_at")

  venue Venue @relation(fields: [venueId], references: [id])

  @@index([venueId, date])
  @@map("court_blocks")
}

model Booking {
  id           String        @id @default(cuid())
  courtId      String        @map("court_id")
  venueId      String        @map("venue_id")
  playerId     String        @map("player_id")
  date         DateTime      @db.Date
  startTime    DateTime      @map("start_time")
  endTime      DateTime      @map("end_time")
  status       BookingStatus @default(confirmed)
  priceInCents Int           @map("price_in_cents")
  coPlayerIds  String[]      @map("co_player_ids")
  createdAt    DateTime      @default(now()) @map("created_at")
  cancelledAt  DateTime?     @map("cancelled_at")

  court  Court  @relation(fields: [courtId], references: [id])
  venue  Venue  @relation(fields: [venueId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@unique([courtId, date, startTime])
  @@index([venueId, date])
  @@index([playerId])
  @@map("bookings")
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("otp_codes")
}

enum LessonType {
  private
  group
}

enum CoachLessonStatus {
  confirmed
  completed
  cancelled
  no_show
}

model CoachPackage {
  id               String     @id @default(cuid())
  coachId          String     @map("coach_id")
  venueId          String     @map("venue_id")
  name             String
  description      String?
  lessonType       LessonType @map("lesson_type")
  durationMin      Int        @map("duration_min")
  priceInCents     Int        @map("price_in_cents")
  sessionsIncluded Int        @default(1) @map("sessions_included")
  active           Boolean    @default(true)
  sortOrder        Int        @default(0) @map("sort_order")
  createdAt        DateTime   @default(now()) @map("created_at")

  coach   StaffMember   @relation(fields: [coachId], references: [id])
  venue   Venue         @relation(fields: [venueId], references: [id])
  lessons CoachLesson[]

  @@index([coachId])
  @@index([venueId])
  @@map("coach_packages")
}

model CoachLesson {
  id            String            @id @default(cuid())
  venueId       String            @map("venue_id")
  coachId       String            @map("coach_id")
  playerId      String            @map("player_id")
  courtId       String?           @map("court_id")
  packageId     String            @map("package_id")
  date          DateTime          @db.Date
  startTime     DateTime          @map("start_time")
  endTime       DateTime          @map("end_time")
  status        CoachLessonStatus @default(confirmed)
  priceInCents  Int               @map("price_in_cents")
  note          String?
  paymentStatus String            @default("UNPAID") @map("payment_status")
  paidAt        DateTime?         @map("paid_at")
  paymentMethod String?           @map("payment_method")
  proofUrl      String?           @map("proof_url")
  paymentNote   String?           @map("payment_note")
  createdAt     DateTime          @default(now()) @map("created_at")
  cancelledAt   DateTime?         @map("cancelled_at")

  venue   Venue        @relation(fields: [venueId], references: [id])
  coach   StaffMember  @relation(fields: [coachId], references: [id])
  player  Player       @relation(fields: [playerId], references: [id])
  court   Court?       @relation(fields: [courtId], references: [id])
  package CoachPackage @relation(fields: [packageId], references: [id])

  @@index([venueId, date])
  @@index([coachId, date])
  @@index([playerId])
  @@map("coach_lessons")
}

model FaceAttempt {
  id                  String   @id @default(cuid())
  eventId             String   @map("event_id")
  matchedPlayerId     String?  @map("matched_player_id")
  resultType          String   @map("result_type")
  /// Staff kiosk: phone used when check-in is confirmed via phone fallback (digits-normalized lookup).
  phoneNumber         String?  @map("phone_number")
  confidence          Float?
  imageUrl            String?  @map("image_url")
  createdNewPlayer    Boolean @default(false) @map("created_new_player")
  hostReviewed        Boolean @default(false) @map("host_reviewed")
  queueNumberAssigned Int?     @map("queue_number_assigned")
  kioskDeviceId       String?  @map("kiosk_device_id")
  createdAt           DateTime @default(now()) @map("created_at")

  matchedPlayer Player? @relation(fields: [matchedPlayerId], references: [id])

  @@index([eventId])
  @@index([createdAt])
  @@map("face_attempts")
}

model PendingPayment {
  id              String    @id @default(cuid())
  venueId         String    @map("venue_id")
  sessionId       String?   @map("session_id")
  playerId        String?   @map("player_id")
  checkInPlayerId String?   @map("check_in_player_id")
  paymentRef      String?   @unique @map("payment_ref")
  amount          Int
  paymentMethod   String    @default("vietqr") @map("payment_method")
  type            String    // "checkin" | "registration" | "subscription"
  status          String    @default("pending") // "pending" | "confirmed" | "cancelled" | "expired"
  createdAt       DateTime  @default(now()) @map("created_at")
  expiresAt       DateTime  @map("expires_at")
  confirmedAt     DateTime? @map("confirmed_at")
  confirmedBy     String?   @map("confirmed_by")
  cancelReason    String?   @map("cancel_reason") // "refunded" | "mistake" — set when a confirmed payment is voided
  cancelledAt     DateTime? @map("cancelled_at")

  venue         Venue          @relation(fields: [venueId], references: [id])
  session       Session?       @relation(fields: [sessionId], references: [id])
  player        Player?        @relation(fields: [playerId], references: [id])
  checkInPlayer CheckInPlayer? @relation(fields: [checkInPlayerId], references: [id])

  @@index([venueId, status])
  @@index([sessionId])
  @@index([paymentRef])
  @@map("pending_payments")
}

model KioskDevice {
  id       String  @id @default(cuid())
  name     String
  location String?
  active   Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("kiosk_devices")
}

// ─── CourtPay Module ─────────────────────────────────────────

model CheckInPlayer {
  id         String   @id @default(cuid())
  venueId    String   @map("venue_id")
  name       String
  phone      String
  gender     String?
  skillLevel String?  @map("skill_level")
  createdAt  DateTime @default(now()) @map("created_at")

  venue         Venue                @relation(fields: [venueId], references: [id])
  subscriptions PlayerSubscription[]
  payments      PendingPayment[]
  checkIns      CheckInRecord[]

  @@unique([phone, venueId])
  @@index([venueId])
  @@map("check_in_players")
}

model SubscriptionPackage {
  id           String   @id @default(cuid())
  venueId      String   @map("venue_id")
  name         String
  sessions     Int?
  durationDays Int      @map("duration_days")
  price        Int
  perks        String?
  isActive     Boolean  @default(true) @map("is_active")
  discountPct  Int?     @map("discount_pct")
  isBestChoice Boolean  @default(false) @map("is_best_choice")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  venue         Venue                @relation(fields: [venueId], references: [id])
  subscriptions PlayerSubscription[]

  @@index([venueId, isActive])
  @@map("subscription_packages")
}

model PlayerSubscription {
  id                String             @id @default(cuid())
  playerId          String             @map("player_id")
  packageId         String             @map("package_id")
  venueId           String             @map("venue_id")
  status            SubscriptionStatus @default(active)
  sessionsRemaining Int?               @map("sessions_remaining")
  activatedAt       DateTime           @default(now()) @map("activated_at")
  expiresAt         DateTime           @map("expires_at")
  paymentRef        String?            @map("payment_ref")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  player  CheckInPlayer       @relation(fields: [playerId], references: [id])
  package SubscriptionPackage @relation(fields: [packageId], references: [id])
  usages  SubscriptionUsage[]

  @@index([playerId, status])
  @@index([venueId, status])
  @@map("player_subscriptions")
}

model SubscriptionUsage {
  id             String   @id @default(cuid())
  subscriptionId String   @map("subscription_id")
  checkedInAt    DateTime @default(now()) @map("checked_in_at")

  subscription PlayerSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@map("subscription_usages")
}

model StaffPushToken {
  id         String   @id @default(cuid())
  staffId    String   @map("staff_id")
  venueId    String   @map("venue_id")
  token      String
  platform   String   @default("android")
  deviceId   String?  @map("device_id")
  active     Boolean  @default(true)
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, token])
  @@index([venueId, active])
  @@map("staff_push_tokens")
}

model CheckInRecord {
  id          String   @id @default(cuid())
  playerId    String   @map("player_id")
  venueId     String   @map("venue_id")
  checkedInAt DateTime @default(now()) @map("checked_in_at")
  paymentId   String?  @map("payment_id")
  source      String   // "vietqr" | "cash" | "subscription"

  player CheckInPlayer @relation(fields: [playerId], references: [id])
  venue  Venue         @relation(fields: [venueId], references: [id])

  @@index([venueId, checkedInAt])
  @@index([playerId])
  @@map("check_in_records")
}

// ─── Billing Module ─────────────────────────────────────────

model BillingConfig {
  id                String   @id @default("default")
  bankBin           String   @default("") @map("bank_bin")
  bankAccount       String   @default("") @map("bank_account")
  bankOwner         String   @default("") @map("bank_owner")
  defaultBaseRate   Int      @default(5000) @map("default_base_rate")
  defaultSubAddon   Int      @default(1000) @map("default_sub_addon")
  defaultSepayAddon Int      @default(1000) @map("default_sepay_addon")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("billing_config")
}

model VenueBillingRate {
  id                 String   @id @default(cuid())
  venueId            String   @unique @map("venue_id")
  baseRatePerCheckin Int      @default(5000) @map("base_rate_per_checkin")
  subscriptionAddon  Int      @default(1000) @map("subscription_addon")
  sepayAddon         Int      @default(1000) @map("sepay_addon")
  /// When true the weekly invoice total is set to 0 (free tier / promotional)
  isFree             Boolean  @default(false) @map("is_free")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  venue Venue @relation(fields: [venueId], references: [id])

  @@map("venue_billing_rates")
}

model BillingInvoice {
  id                   String    @id @default(cuid())
  venueId              String    @map("venue_id")
  weekStartDate        DateTime  @map("week_start_date")
  weekEndDate          DateTime  @map("week_end_date")
  totalCheckins        Int       @default(0) @map("total_checkins")
  subscriptionCheckins Int       @default(0) @map("subscription_checkins")
  sepayCheckins        Int       @default(0) @map("sepay_checkins")
  baseAmount           Int       @default(0) @map("base_amount")
  subscriptionAmount   Int       @default(0) @map("subscription_amount")
  sepayAmount          Int       @default(0) @map("sepay_amount")
  totalAmount          Int       @default(0) @map("total_amount")
  status               String    @default("pending") // "pending" | "paid" | "overdue"
  paymentRef           String?   @unique @map("payment_ref")
  paidAt               DateTime? @map("paid_at")
  confirmedBy          String?   @map("confirmed_by") // "sepay" | "manual_admin"
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  venue     Venue             @relation(fields: [venueId], references: [id])
  lineItems BillingLineItem[]

  @@unique([venueId, weekStartDate])
  @@index([venueId, status])
  @@map("billing_invoices")
}

model BillingLineItem {
  id              String   @id @default(cuid())
  invoiceId       String   @map("invoice_id")
  checkInRecordId String   @map("check_in_record_id")
  playerId        String   @map("player_id")
  checkedInAt     DateTime @map("checked_in_at")
  baseRate        Int      @map("base_rate")
  subscriptionAddon Int    @default(0) @map("subscription_addon")
  sepayAddon      Int      @default(0) @map("sepay_addon")
  lineTotal       Int      @map("line_total")

  invoice BillingInvoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("billing_line_items")
}
