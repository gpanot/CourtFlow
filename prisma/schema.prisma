generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SkillLevel {
  beginner
  intermediate
  advanced
  pro
}

enum Gender {
  male
  female
  other
}

enum CourtStatus {
  idle
  warmup
  active
  maintenance
}

enum GameType {
  men
  women
  mixed
}

enum SessionStatus {
  open
  closed
}

enum SessionType {
  open_play
  competition
}

enum CourtBlockType {
  private_competition
  private_event
  maintenance
  open_play
  competition
}

enum QueueStatus {
  waiting
  assigned
  playing
  on_break
  left
}

enum GroupStatus {
  forming
  active
  disbanded
}

enum GamePreference {
  no_preference
  same_gender
}

enum StaffRole {
  staff
  superadmin
}

enum PaymentStatus {
  UNPAID
  PAID
}

enum MembershipStatus {
  active
  suspended
  expired
  cancelled
}

enum MembershipPaymentStatus {
  UNPAID
  PAID
  OVERDUE
}

enum BookingStatus {
  confirmed
  cancelled
  completed
  no_show
}

model Venue {
  id                 String    @id @default(cuid())
  name               String
  location           String?
  settings           Json      @default("{}")
  active             Boolean   @default(true)
  expectedMaxPlayers Int?      @map("expected_max_players")
  playFrequency      String?   @map("play_frequency")
  playTypes          String[]  @default([]) @map("play_types")
  painPoints         String[]  @default([]) @map("pain_points")
  logoUrl            String?   @map("logo_url")
  tvText             String?   @map("tv_text")
  createdAt          DateTime  @default(now()) @map("created_at")

  courts          Court[]
  sessions        Session[]
  staff           StaffMember[]
  auditLogs       AuditLog[]
  membershipTiers MembershipTier[]
  memberships     Membership[]
  bookings        Booking[]
  courtBlocks     CourtBlock[]
  coachPackages   CoachPackage[]
  coachLessons    CoachLesson[]

  @@map("venues")
}

model Player {
  id                    String         @id @default(cuid())
  name                  String
  phone                 String         @unique
  avatar                String         @default("🏓")
  skillLevel            SkillLevel     @default(beginner) @map("skill_level")
  gender                Gender
  gamePreference        GamePreference @default(no_preference) @map("game_preference")
  notificationsEnabled  Boolean        @default(false) @map("notifications_enabled")
  faceSubjectId         String?        @map("face_subject_id")
  createdAt             DateTime       @default(now()) @map("created_at")

  queueEntries      QueueEntry[]
  pushSubscriptions PushSubscription[]
  memberships       Membership[]
  bookings          Booking[]
  coachLessons      CoachLesson[]
  faceAttempts      FaceAttempt[]

  @@map("players")
}

model PushSubscription {
  id        String   @id @default(cuid())
  playerId  String   @map("player_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model StaffMember {
  id                  String    @id @default(cuid())
  name                String
  phone               String    @unique
  email               String?   @unique
  role                StaffRole @default(staff)
  passwordHash        String    @map("password_hash")
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  isCoach             Boolean   @default(false) @map("is_coach")
  coachBio            String?   @map("coach_bio")
  coachPhoto          String?   @map("coach_photo")
  createdAt           DateTime  @default(now()) @map("created_at")

  venues        Venue[]
  auditLogs     AuditLog[]
  sessions      Session[]
  payments      StaffPayment[]  @relation("StaffPayments")
  paidPayments  StaffPayment[]  @relation("PaidByStaff")
  coachPackages CoachPackage[]
  coachLessons  CoachLesson[]

  @@map("staff_members")
}

model Court {
  id              String      @id @default(cuid())
  venueId         String      @map("venue_id")
  label           String
  status          CourtStatus @default(idle)
  activeInSession Boolean     @default(false) @map("active_in_session")
  isBookable      Boolean     @default(false) @map("is_bookable")
  /** After staff restores from maintenance/stand-by, assignments skip warmup until next maintenance. */
  skipWarmupAfterMaintenance Boolean @default(false) @map("skip_warmup_after_maintenance")

  venue            Venue              @relation(fields: [venueId], references: [id])
  courtAssignments CourtAssignment[]
  bookings         Booking[]
  coachLessons     CoachLesson[]

  @@map("courts")
}

model Session {
  id           String        @id @default(cuid())
  venueId      String        @map("venue_id")
  staffId      String?       @map("staff_id")
  date         DateTime      @default(now())
  openedAt     DateTime      @default(now()) @map("opened_at")
  closedAt     DateTime?     @map("closed_at")
  status       SessionStatus @default(open)
  type         SessionType   @default(open_play)
  title        String?
  gameTypeMix  Json?         @map("game_type_mix")
  warmupMode   String        @default("manual") @map("warmup_mode")
  /// After the first real game starts, no new warm-up courts/assignments for this session.
  introWarmupComplete Boolean @default(false) @map("intro_warmup_complete")
  maxPlayers   Int?          @map("max_players")

  venue            Venue              @relation(fields: [venueId], references: [id])
  staff            StaffMember?       @relation(fields: [staffId], references: [id])
  queueEntries     QueueEntry[]
  playerGroups     PlayerGroup[]
  courtAssignments CourtAssignment[]

  @@map("sessions")
}

model QueueEntry {
  id                    String         @id @default(cuid())
  sessionId             String         @map("session_id")
  playerId              String         @map("player_id")
  groupId               String?        @map("group_id")
  joinedAt              DateTime       @default(now()) @map("joined_at")
  status                QueueStatus    @default(waiting)
  breakUntil            DateTime?      @map("break_until")
  totalPlayMinutesToday Int            @default(0) @map("total_play_minutes_today")
  gamePreference        GamePreference @default(no_preference) @map("game_preference")
  queueNumber           Int?           @map("queue_number")

  session Session      @relation(fields: [sessionId], references: [id])
  player  Player       @relation(fields: [playerId], references: [id])
  group   PlayerGroup? @relation(fields: [groupId], references: [id])

  @@unique([sessionId, playerId])
  @@map("queue_entries")
}

model PlayerGroup {
  id        String      @id @default(cuid())
  sessionId String      @map("session_id")
  code      String
  status    GroupStatus  @default(forming)
  createdAt DateTime    @default(now()) @map("created_at")

  session      Session      @relation(fields: [sessionId], references: [id])
  queueEntries QueueEntry[]

  @@unique([sessionId, code])
  @@map("player_groups")
}

model CourtAssignment {
  id        String    @id @default(cuid())
  courtId   String    @map("court_id")
  sessionId String    @map("session_id")
  playerIds String[]  @map("player_ids")
  groupIds  String[]  @map("group_ids")
  gameType  GameType  @default(mixed) @map("game_type")
  isWarmup  Boolean   @default(false) @map("is_warmup")
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  endedBy   String?   @map("ended_by")

  court   Court   @relation(fields: [courtId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  @@map("court_assignments")
}

model AuditLog {
  id        String   @id @default(cuid())
  venueId   String   @map("venue_id")
  staffId   String?  @map("staff_id")
  action    String
  targetId  String?  @map("target_id")
  reason    String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  venue Venue        @relation(fields: [venueId], references: [id])
  staff StaffMember? @relation(fields: [staffId], references: [id])

  @@map("audit_logs")
}

model StaffPayment {
  id        String        @id @default(cuid())
  staffId   String        @map("staff_id")
  weekStart DateTime      @map("week_start")
  totalHours Decimal      @db.Decimal(6, 1) @map("total_hours")
  amount        Decimal?      @db.Decimal(10, 0)
  paymentMethod String?       @map("payment_method")
  status        PaymentStatus @default(UNPAID)
  paidAt    DateTime?     @map("paid_at")
  paidDate  DateTime?     @map("paid_date")
  paidById  String?       @map("paid_by_id")
  note      String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  staff  StaffMember  @relation("StaffPayments", fields: [staffId], references: [id])
  paidBy StaffMember? @relation("PaidByStaff", fields: [paidById], references: [id])

  @@unique([staffId, weekStart])
  @@index([weekStart])
  @@index([staffId])
  @@map("staff_payments")
}

model MembershipTier {
  id               String   @id @default(cuid())
  venueId          String   @map("venue_id")
  sortOrder        Int      @map("sort_order")
  name             String
  priceInCents     Int      @map("price_in_cents")
  sessionsIncluded Int?     @map("sessions_included")
  showBadge        Boolean  @default(false) @map("show_badge")
  perks            Json     @default("[]")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")

  venue       Venue        @relation(fields: [venueId], references: [id])
  memberships Membership[]

  @@unique([venueId, sortOrder])
  @@map("membership_tiers")
}

model Membership {
  id           String           @id @default(cuid())
  playerId     String           @map("player_id")
  venueId      String           @map("venue_id")
  tierId       String           @map("tier_id")
  status       MembershipStatus @default(active)
  activatedAt  DateTime         @default(now()) @map("activated_at")
  renewalDate  DateTime         @map("renewal_date")
  sessionsUsed Int              @default(0) @map("sessions_used")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  player   Player              @relation(fields: [playerId], references: [id])
  venue    Venue               @relation(fields: [venueId], references: [id])
  tier     MembershipTier      @relation(fields: [tierId], references: [id])
  payments MembershipPayment[]

  @@unique([playerId, venueId])
  @@index([venueId])
  @@index([tierId])
  @@map("memberships")
}

model MembershipPayment {
  id            String                  @id @default(cuid())
  membershipId  String                  @map("membership_id")
  periodStart   DateTime                @map("period_start")
  periodEnd     DateTime                @map("period_end")
  amountInCents Int                     @map("amount_in_cents")
  status        MembershipPaymentStatus @default(UNPAID)
  paidAt        DateTime?               @map("paid_at")
  paymentMethod String?                 @map("payment_method")
  proofUrl      String?                 @map("proof_url")
  note          String?
  createdAt     DateTime                @default(now()) @map("created_at")

  membership Membership @relation(fields: [membershipId], references: [id])

  @@index([membershipId])
  @@index([status])
  @@map("membership_payments")
}

model CourtBlock {
  id        String         @id @default(cuid())
  venueId   String         @map("venue_id")
  type      CourtBlockType
  title     String?
  note      String?
  courtIds  String[]       @map("court_ids")
  date      DateTime       @db.Date
  startTime DateTime       @map("start_time")
  endTime   DateTime       @map("end_time")
  createdBy String?        @map("created_by")
  createdAt DateTime       @default(now()) @map("created_at")

  venue Venue @relation(fields: [venueId], references: [id])

  @@index([venueId, date])
  @@map("court_blocks")
}

model Booking {
  id           String        @id @default(cuid())
  courtId      String        @map("court_id")
  venueId      String        @map("venue_id")
  playerId     String        @map("player_id")
  date         DateTime      @db.Date
  startTime    DateTime      @map("start_time")
  endTime      DateTime      @map("end_time")
  status       BookingStatus @default(confirmed)
  priceInCents Int           @map("price_in_cents")
  coPlayerIds  String[]      @map("co_player_ids")
  createdAt    DateTime      @default(now()) @map("created_at")
  cancelledAt  DateTime?     @map("cancelled_at")

  court  Court  @relation(fields: [courtId], references: [id])
  venue  Venue  @relation(fields: [venueId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@unique([courtId, date, startTime])
  @@index([venueId, date])
  @@index([playerId])
  @@map("bookings")
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("otp_codes")
}

enum LessonType {
  private
  group
}

enum CoachLessonStatus {
  confirmed
  completed
  cancelled
  no_show
}

model CoachPackage {
  id               String     @id @default(cuid())
  coachId          String     @map("coach_id")
  venueId          String     @map("venue_id")
  name             String
  description      String?
  lessonType       LessonType @map("lesson_type")
  durationMin      Int        @map("duration_min")
  priceInCents     Int        @map("price_in_cents")
  sessionsIncluded Int        @default(1) @map("sessions_included")
  active           Boolean    @default(true)
  sortOrder        Int        @default(0) @map("sort_order")
  createdAt        DateTime   @default(now()) @map("created_at")

  coach   StaffMember   @relation(fields: [coachId], references: [id])
  venue   Venue         @relation(fields: [venueId], references: [id])
  lessons CoachLesson[]

  @@index([coachId])
  @@index([venueId])
  @@map("coach_packages")
}

model CoachLesson {
  id            String            @id @default(cuid())
  venueId       String            @map("venue_id")
  coachId       String            @map("coach_id")
  playerId      String            @map("player_id")
  courtId       String?           @map("court_id")
  packageId     String            @map("package_id")
  date          DateTime          @db.Date
  startTime     DateTime          @map("start_time")
  endTime       DateTime          @map("end_time")
  status        CoachLessonStatus @default(confirmed)
  priceInCents  Int               @map("price_in_cents")
  note          String?
  paymentStatus String            @default("UNPAID") @map("payment_status")
  paidAt        DateTime?         @map("paid_at")
  paymentMethod String?           @map("payment_method")
  proofUrl      String?           @map("proof_url")
  paymentNote   String?           @map("payment_note")
  createdAt     DateTime          @default(now()) @map("created_at")
  cancelledAt   DateTime?         @map("cancelled_at")

  venue   Venue        @relation(fields: [venueId], references: [id])
  coach   StaffMember  @relation(fields: [coachId], references: [id])
  player  Player       @relation(fields: [playerId], references: [id])
  court   Court?       @relation(fields: [courtId], references: [id])
  package CoachPackage @relation(fields: [packageId], references: [id])

  @@index([venueId, date])
  @@index([coachId, date])
  @@index([playerId])
  @@map("coach_lessons")
}

model FaceAttempt {
  id                  String   @id @default(cuid())
  eventId             String   @map("event_id")
  matchedPlayerId     String?  @map("matched_player_id")
  resultType          String   @map("result_type")
  confidence          Float?
  imageUrl            String?  @map("image_url")
  createdNewPlayer    Boolean @default(false) @map("created_new_player")
  hostReviewed        Boolean @default(false) @map("host_reviewed")
  queueNumberAssigned Int?     @map("queue_number_assigned")
  kioskDeviceId       String?  @map("kiosk_device_id")
  createdAt           DateTime @default(now()) @map("created_at")

  matchedPlayer Player? @relation(fields: [matchedPlayerId], references: [id])

  @@index([eventId])
  @@index([createdAt])
  @@map("face_attempts")
}

model KioskDevice {
  id       String  @id @default(cuid())
  name     String
  location String?
  active   Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("kiosk_devices")
}
