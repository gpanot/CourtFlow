DATABASE_URL="postgresql://username:password@localhost:5432/courtflow"
JWT_SECRET="your-jwt-secret-here"
NODE_ENV="development"

# AWS Rekognition Face Recognition
AWS_ACCESS_KEY_ID="your-access-key-here"
AWS_SECRET_ACCESS_KEY="your-secret-access-key-here"
AWS_REGION="ap-southeast-1"
AWS_REKOGNITION_COLLECTION="courtflow-players"
# Optional: documented in docs/aws-face-recognition.md — compare/diagnostics; SearchFaces threshold is 85 in code unless changed
# AWS_REKOGNITION_FACE_MATCH_THRESHOLD="85"
# FapiHub — background removal (admin re-enrollment) and background blur (registration)
FAPIHUB_API_KEY=""

# Site-wide gate — only enforced when SITE_GATE_ENABLED=true
# SITE_PASSWORD="CourtFlow2026!"

# WebSocket
NEXT_PUBLIC_WEBSOCKET_URL="ws://localhost:3000"

# scripts/seed-bots.ts — only needed when SITE_GATE_ENABLED=true
# COURTFLOW_GATE_COOKIE="cf-site-access=granted"
# Optional: target venue (default demo-venue-1)
# COURTFLOW_VENUE_ID="cmn491rh50000t5tpeq9u8tqg"
# Optional: bot gender mix — % male (rest female), or pass as 5th CLI arg after delay
# COURTFLOW_BOT_MEN_PERCENT=60

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# SePay webhook auth (optional in local dev, required in production)
SEPAY_WEBHOOK_SECRET=""

# OpenAI — used for AI sticker generation (gpt-image-1 images.edit)
OPENAI_API_KEY=""

# Resend — transactional email
RESEND_API_KEY="re_placeholder"

# Player Booking Portal
NEXT_PUBLIC_VENUE_ID=""
AUTH_SECRET="" # Generate with: npx auth secret
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Apple OAuth — Services ID from Apple Developer → Identifiers → Services IDs
# APPLE_CLIENT_ID="com.courtflow.web"
# APPLE_CLIENT_SECRET=""  # JWT generated from .p8 key (expires ~180 days — must rotate)
