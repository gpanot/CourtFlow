DATABASE_URL="postgresql://username:password@localhost:5432/courtflow"
JWT_SECRET="your-jwt-secret-here"
NODE_ENV="development"

# CompreFace Face Recognition
COMPREFACE_API_URL="https://your-compreface-app.railway.app/api/v1"
COMPREFACE_API_KEY="your-api-key-here"
COMPREFACE_COLLECTION_NAME="courtflow_players"

# Site-wide gate — only enforced when SITE_GATE_ENABLED=true
# SITE_PASSWORD="CourtFlow2026!"

# WebSocket
NEXT_PUBLIC_WEBSOCKET_URL="ws://localhost:3000"

# scripts/seed-bots.ts — only needed when SITE_GATE_ENABLED=true
# COURTFLOW_GATE_COOKIE="cf-site-access=granted"
# Optional: target venue (default demo-venue-1)
# COURTFLOW_VENUE_ID="cmn491rh50000t5tpeq9u8tqg"
# Optional: bot gender mix — % male (rest female), or pass as 5th CLI arg after delay
# COURTFLOW_BOT_MEN_PERCENT=60

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
